<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:OpenBurningSuite.Views"
             x:Class="OpenBurningSuite.Views.WriteView"
             Background="#0C1622">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="16">

            <!-- Header -->
            <TextBlock Text="Write / Burn Disc" Classes="PageTitle"/>
            <TextBlock Text="Write disc images or build on-the-fly to CD, DVD, HD DVD, or Blu-ray media."
                       Classes="PageSubtitle"/>

            <!-- Source -->
            <Border Classes="Card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Source" Classes="SectionHeader"/>

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <RadioButton x:Name="RdoImageFile"
                                     Content="Image File" Foreground="#E8F0FE"
                                     IsChecked="True" GroupName="SourceMode"
                                     IsCheckedChanged="OnSourceModeChanged"
                                     ToolTip.Tip="Burn a pre-existing disc image file"/>
                        <RadioButton x:Name="RdoBuildOnTheFly"
                                     Content="Build on the fly"
                                     Foreground="#E8F0FE"
                                     GroupName="SourceMode"
                                     IsCheckedChanged="OnSourceModeChanged"
                                     ToolTip.Tip="Select files and folders to build and burn directly to disc without creating a separate image file first"/>
                    </StackPanel>

                    <!-- Image File mode panel -->
                    <StackPanel x:Name="PnlImageFile" Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox x:Name="TxtImagePath"
                                     Watermark="Image file path (.iso, .bin, .chd, .nrg, .mdf, .cdi, .img)..."
                                     Background="#152030" Foreground="#E8F0FE"
                                     ToolTip.Tip="Path to the disc image file (.iso, .bin, .chd, .nrg, .mdf, .cdi, .img)"
                                     DragDrop.AllowDrop="True"
                                     DragDrop.DragOver="OnImageDragOver"
                                     DragDrop.Drop="OnImageDrop"/>
                            <Button x:Name="BtnBrowseImage" Grid.Column="1"
                                    Content="Browse…" Classes="ActionBtn"
                                    Margin="6,0,0,0" Click="OnBrowseImageClick"
                                    ToolTip.Tip="Browse for a disc image file"/>
                        </Grid>
                        <TextBlock Text="💡 Drag and drop a disc image file here" Foreground="#5A7A9A" FontSize="10" Margin="0,2,0,0"/>
                        <TextBlock x:Name="TxtImageInfo" Text="" Foreground="#5A7A9A" FontSize="10" Margin="0,2,0,0"/>

                        <!-- Encrypted image detection -->
                        <StackPanel x:Name="PnlDecryptImage" IsVisible="False" Spacing="6"
                                    Margin="0,4,0,0">
                            <TextBlock Text="🔒 This image is encrypted (OBS format). Enter the password to decrypt before burning:"
                                       Foreground="#FFB347" FontSize="11" TextWrapping="Wrap"/>
                            <TextBox x:Name="TxtDecryptPassword"
                                     PasswordChar="●"
                                     Watermark="Enter decryption password..."
                                     Background="#152030" Foreground="#E8F0FE"
                                     ToolTip.Tip="Password to decrypt the encrypted disc image"/>
                        </StackPanel>

                        <!-- PS3 encrypted ISO detection -->
                        <Border x:Name="PnlWritePs3Decrypt" IsVisible="False"
                                Background="#1A1520" CornerRadius="6" Padding="12" Margin="0,4,0,0"
                                BorderBrush="#3A2050" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="🔐 PS3 ISO Decryption" FontSize="13"
                                           Foreground="#BB86FC" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtWritePs3Info" Text=""
                                           Foreground="#FFB347" FontSize="11" TextWrapping="Wrap"/>

                                <!-- Key source selection -->
                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                    <RadioButton x:Name="RdoWritePs3Ird" Content="IRD File"
                                                 IsChecked="True" Foreground="#E8F0FE"
                                                 GroupName="WritePs3KeySource"
                                                 IsCheckedChanged="OnWritePs3KeySourceChanged"/>
                                    <RadioButton x:Name="RdoWritePs3DkeyFile" Content=".dkey File"
                                                 Foreground="#E8F0FE"
                                                 GroupName="WritePs3KeySource"
                                                 IsCheckedChanged="OnWritePs3KeySourceChanged"/>
                                    <RadioButton x:Name="RdoWritePs3HexKey" Content="Hex Key"
                                                 Foreground="#E8F0FE"
                                                 GroupName="WritePs3KeySource"
                                                 IsCheckedChanged="OnWritePs3KeySourceChanged"/>
                                </StackPanel>

                                <!-- IRD / dkey file browse -->
                                <Grid x:Name="PnlWritePs3FileBrowse" ColumnDefinitions="*,Auto">
                                    <TextBox x:Name="TxtWritePs3KeyFilePath" Grid.Column="0"
                                             Watermark="Select IRD or .dkey file..."
                                             Foreground="#E8F0FE" FontSize="12"
                                             IsReadOnly="True"/>
                                    <Button Content="Browse…" Classes="ActionBtn"
                                            Grid.Column="1" Margin="6,0,0,0"
                                            Click="OnBrowseWritePs3KeyFileClick"/>
                                </Grid>

                                <!-- Hex key input -->
                                <TextBox x:Name="TxtWritePs3HexKey" IsVisible="False"
                                         Watermark="Enter 32-character hex disc key..."
                                         Foreground="#E8F0FE" FontSize="12"
                                         MaxLength="32"/>

                                <TextBlock x:Name="TxtWritePs3KeyStatus" Text=""
                                           Foreground="#5A7A9A" FontSize="10" TextWrapping="Wrap"/>

                                <CheckBox x:Name="ChkWritePs3Decrypt"
                                          Content="Decrypt ISO before burning"
                                          IsChecked="True" Foreground="#E8F0FE"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Build on-the-fly mode panel -->
                    <StackPanel x:Name="PnlOnTheFly" Spacing="10" IsVisible="False">
                        <!-- Source folder -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Source Folder:" Classes="FieldLabel"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox x:Name="TxtOtfSourceFolder"
                                         Watermark="Select a folder containing files to burn..."
                                         Background="#152030" Foreground="#E8F0FE"
                                         ToolTip.Tip="Root folder whose contents will be burned to disc. All files and subdirectories are included."
                                         DragDrop.AllowDrop="True"
                                         DragDrop.DragOver="OnFolderDragOver"
                                         DragDrop.Drop="OnFolderDrop"/>
                                <Button x:Name="BtnOtfBrowseFolder" Grid.Column="1"
                                        Content="Browse…" Classes="ActionBtn"
                                        Margin="6,0,0,0" Click="OnOtfBrowseFolderClick"
                                        ToolTip.Tip="Browse for a source folder"/>
                            </Grid>
                        </StackPanel>

                        <!-- Individual files/folders list -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Or add individual files and folders:" Classes="FieldLabel"/>
                            <Border Background="#0A1520" CornerRadius="6" Padding="6" MinHeight="80"
                                    DragDrop.AllowDrop="True"
                                    DragDrop.DragOver="OnFilesDragOver"
                                    DragDrop.Drop="OnFilesDrop">
                                <StackPanel>
                                    <ListBox x:Name="LstOtfFiles"
                                             Background="Transparent" Foreground="#E8F0FE"
                                             MaxHeight="160"
                                             ToolTip.Tip="Files and folders to include on the disc. Drop files here or use the Add buttons."/>
                                    <TextBlock x:Name="TxtOtfFilesHint"
                                               Text="💡 Drag and drop files or folders here"
                                               Foreground="#5A7A9A" FontSize="10"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                <Button x:Name="BtnOtfAddFiles" Content="＋ Add Files"
                                        Classes="ActionBtn" Click="OnOtfAddFilesClick"
                                        ToolTip.Tip="Add individual files to the disc"/>
                                <Button x:Name="BtnOtfAddFolder" Content="📁 Add Folder"
                                        Classes="ActionBtn" Click="OnOtfAddFolderClick"
                                        ToolTip.Tip="Add a folder and all its contents to the disc"/>
                                <Button x:Name="BtnOtfRemove" Content="✕ Remove"
                                        Classes="ActionBtn" Click="OnOtfRemoveClick"
                                        ToolTip.Tip="Remove the selected item from the list"/>
                                <Button x:Name="BtnOtfClearAll" Content="🧹 Clear All"
                                        Classes="ActionBtn" Click="OnOtfClearAllClick"
                                        ToolTip.Tip="Remove all items from the list"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Disc settings for on-the-fly -->
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                <TextBlock Text="Volume Label:" Classes="FieldLabel"/>
                                <TextBox x:Name="TxtOtfVolumeLabel"
                                         Watermark="MY_DISC"
                                         Background="#152030" Foreground="#E8F0FE"
                                         MaxLength="32"
                                         ToolTip.Tip="Volume label for the disc (max 32 characters for ISO 9660)"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="File System:" Classes="FieldLabel"/>
                                <ComboBox x:Name="CmbOtfFileSystem" HorizontalAlignment="Stretch"
                                          ToolTip.Tip="Filesystem format for the disc image. Joliet adds long filename and Unicode support. UDF is required for large files (>4 GB) and Blu-ray."/>
                            </StackPanel>
                        </Grid>

                        <!-- Source info -->
                        <TextBlock x:Name="TxtOtfInfo" Text="" Foreground="#5A7A9A" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Detected Content (auto-populated from image analysis) -->
            <Border x:Name="PnlWriteDetectedContent" Classes="Card" IsVisible="False">
                <StackPanel Spacing="6">
                    <TextBlock Text="🔍  Detected Content" Classes="SectionHeader"/>
                    <TextBlock x:Name="TxtWriteDetectedContent" Text="—" Foreground="#E8F0FE"
                               FontSize="14" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtWriteDetectedPreset" Text=""
                               Foreground="#5A7A9A" FontSize="11" FontStyle="Italic"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Target Drive & Write Settings -->
            <Border Classes="Card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Target Drive &amp; Write Settings" Classes="SectionHeader"/>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                            <TextBlock Text="Drive:" Classes="FieldLabel"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <ComboBox x:Name="CmbDrive" HorizontalAlignment="Stretch"
                                          PlaceholderText="Select burner drive..."
                                          ToolTip.Tip="Select the optical drive to burn to"/>
                                <Button x:Name="BtnRefreshDrives" Grid.Column="1"
                                        Content="🔄" Classes="ActionBtn"
                                        Margin="6,0,0,0" Click="OnRefreshDrivesClick"
                                        ToolTip.Tip="Refresh the list of available drives"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Write Speed:" Classes="FieldLabel"/>
                            <ComboBox x:Name="CmbSpeed" HorizontalAlignment="Stretch"
                                      ToolTip.Tip="Write speed — slower speeds produce more reliable burns"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,8,8,0">
                            <TextBlock Text="Write Mode:" Classes="FieldLabel"/>
                            <ComboBox x:Name="CmbWriteMode" HorizontalAlignment="Stretch"
                                      ToolTip.Tip="DAO writes entire disc at once; TAO writes track-by-track"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="0,8,0,0">
                            <TextBlock Text="Copies:" Classes="FieldLabel"/>
                            <NumericUpDown x:Name="NumCopies" Minimum="1" Maximum="99" Value="1"
                                           Background="#152030" Foreground="#E8F0FE"
                                           ToolTip.Tip="Number of copies to burn"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Burn Options -->
            <Border Classes="Card">
                <StackPanel Spacing="8">
                    <TextBlock Text="Burn Options" Classes="SectionHeader"/>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <CheckBox x:Name="ChkEject" Content="Eject after burn"
                                      IsChecked="True" Foreground="#E8F0FE"
                                      ToolTip.Tip="Automatically eject the disc tray when burning completes"/>
                            <CheckBox x:Name="ChkShowDiscContent" Content="Show disc content after burn"
                                      Foreground="#E8F0FE"
                                      ToolTip.Tip="Open the file explorer to show disc content when burning completes successfully"/>
                            <CheckBox x:Name="ChkVerify" Content="Verify after burn"
                                      Foreground="#E8F0FE"
                                      ToolTip.Tip="Read back and verify data after burning"/>
                            <CheckBox x:Name="ChkSimulate" Content="Simulate / Test write"
                                      Foreground="#E8F0FE"
                                      ToolTip.Tip="Perform a test burn without writing any data"/>
                            <CheckBox x:Name="ChkBurnProof" Content="Buffer underrun protection"
                                      IsChecked="True" Foreground="#E8F0FE"
                                      ToolTip.Tip="Prevent buffer underrun errors during burning"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <CheckBox x:Name="ChkClose" Content="Close / Finalize disc"
                                      IsChecked="True" Foreground="#E8F0FE"
                                      ToolTip.Tip="Finalize the disc (required for playback in standalone players)"/>
                            <CheckBox x:Name="ChkOverburn" Content="Overburn"
                                      Foreground="#E8F0FE"
                                      ToolTip.Tip="Write beyond the official disc capacity (risky)"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Overburn limit (MB):" Foreground="#5A7A9A"
                                           FontSize="11" VerticalAlignment="Center"/>
                                <NumericUpDown x:Name="NumOverburnMB"
                                               Minimum="0" Maximum="100" Value="0"
                                               Width="80" IsEnabled="False"
                                               Background="#152030" Foreground="#E8F0FE"
                                               ToolTip.Tip="Extra megabytes beyond rated capacity"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Multi-session -->
            <Border Classes="Card">
                <StackPanel Spacing="8">
                    <TextBlock Text="Multi-Session" Classes="SectionHeader"/>
                    <ComboBox x:Name="CmbMultiSession" HorizontalAlignment="Stretch"
                              ToolTip.Tip="Single session closes the disc; multi-session allows adding more data later">
                        <ComboBoxItem Content="Close (Single Session)"/>
                        <ComboBoxItem Content="Start (Multi-session)"/>
                        <ComboBoxItem Content="Continue (Append session)"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Advanced Options -->
            <Expander Header="⚙&#xFE0F;  Advanced Options" Classes="SettingsExpander">
                <StackPanel Spacing="10" Margin="0,8,0,0">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                            <TextBlock Text="Force Media Type:" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtForceMediaType" Background="#152030"
                                     Foreground="#E8F0FE"
                                     Watermark="e.g. CD-R, DVD+R (optional)"
                                     ToolTip.Tip="Override automatic media type detection"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock Text="BD-R Mode:" Classes="FieldLabel"/>
                            <ComboBox x:Name="CmbBdRMode" HorizontalAlignment="Stretch"
                                      ToolTip.Tip="Blu-ray recording mode">
                                <ComboBoxItem Content="SRM (Sequential Recording)"/>
                                <ComboBoxItem Content="SRM+POW"/>
                                <ComboBoxItem Content="RRM (Random Recording)"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,8,8,0">
                            <TextBlock Text="DVD Layer Break:" Classes="FieldLabel"/>
                            <NumericUpDown x:Name="NumLayerBreak"
                                           Minimum="0" Maximum="999999" Value="0"
                                           Background="#152030" Foreground="#E8F0FE"
                                           ToolTip.Tip="Layer break position for dual-layer DVD"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Gaming Patches -->
            <Expander Header="🎮  Gaming Patches &amp; Special Formats" Classes="SettingsExpander">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <CheckBox x:Name="ChkLibCrypt"
                              Content="Apply LibCrypt protection (PS1 SBI file)"
                              Foreground="#E8F0FE"
                              ToolTip.Tip="Enable LibCrypt copy protection patching for PlayStation 1 games"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox x:Name="TxtSbiPath"
                                 Watermark="LibCrypt .sbi file path..."
                                 Background="#152030" Foreground="#E8F0FE" IsEnabled="False"
                                 ToolTip.Tip="Path to the LibCrypt .sbi file for PS1 game protection"
                                 DragDrop.AllowDrop="True"
                                 DragDrop.DragOver="OnImageDragOver"
                                 DragDrop.Drop="OnSbiDrop"/>
                        <Button x:Name="BtnBrowseSbi" Grid.Column="1"
                                Content="Browse…" Classes="ActionBtn"
                                Margin="6,0,0,0" IsEnabled="False"
                                Click="OnBrowseSbiClick"
                                ToolTip.Tip="Browse for a LibCrypt .sbi file"/>
                    </Grid>
                    <CheckBox x:Name="ChkDcGdi"
                              Content="Sega Dreamcast GDI/CDI patching"
                              Foreground="#E8F0FE"
                              ToolTip.Tip="Apply GDI/CDI patching for Sega Dreamcast disc images"/>
                    <CheckBox x:Name="ChkRegionFree"
                              Content="Region-free patching"
                              Foreground="#E8F0FE"
                              ToolTip.Tip="Remove region restrictions from the disc image"/>
                    <CheckBox x:Name="ChkBootPatch"
                              Content="Boot sector patching"
                              Foreground="#E8F0FE"
                              ToolTip.Tip="Patch the boot sector for compatibility with modified firmware"/>
                    <CheckBox x:Name="ChkEsrPatch"
                              Content="ESR patch (PS2 DVD-R)"
                              Foreground="#E8F0FE"
                              ToolTip.Tip="Inject DVD-Video UDF structure for PS2 MechaCon bypass on DVD-R media"/>
                    <CheckBox x:Name="ChkMasterDiscPatch"
                              Content="Master Disc patch (PS2)"
                              Foreground="#E8F0FE"
                              ToolTip.Tip="Apply Master Disc patch for MechaPwn DEX PS2 consoles"/>
                    <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding #ChkMasterDiscPatch.IsChecked}">
                        <TextBlock Text="Region:" Foreground="#8EAFC8" FontSize="12"
                                   VerticalAlignment="Center" Margin="24,0,8,0"/>
                        <ComboBox x:Name="CmbMasterDiscRegion" Grid.Column="1"
                                  Background="#152030" Foreground="#E8F0FE"
                                  SelectedIndex="1"
                                  ToolTip.Tip="Region for Master Disc patch">
                            <ComboBoxItem Content="NTSC-J" Tag="NTSC-J"/>
                            <ComboBoxItem Content="NTSC-U" Tag="NTSC-U"/>
                            <ComboBoxItem Content="PAL" Tag="PAL"/>
                            <ComboBoxItem Content="WORLD" Tag="WORLD"/>
                        </ComboBox>
                    </Grid>
                    <CheckBox x:Name="ChkPsx80Min"
                              Content="PSX 80 Minute patch (PS1/PS2 CD-R)"
                              Foreground="#E8F0FE"
                              ToolTip.Tip="Append dummy sectors for 80-minute CD-R compatibility"/>
                    <CheckBox x:Name="ChkPsxUndither"
                              Content="PSX Undither patch (PS1)"
                              Foreground="#E8F0FE"
                              ToolTip.Tip="Remove GPU dithering patterns from PS1 game images"/>
                    <TextBlock Text="⚠&#xFE0F; Use gaming patches only for legally owned software."
                               Foreground="#FF8C00" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Expander>

            <!-- Progress & Log -->
            <Border Classes="Card">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Text="Burn Progress" Classes="SectionHeader"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnBurn" Grid.Column="1"
                                Content="🔥  Burn" Classes="PrimaryBtn"
                                Margin="0,0,8,0" Click="OnBurnClick"
                                ToolTip.Tip="Start burning the image to disc"/>
                        <Button x:Name="BtnCancel" Grid.Column="2"
                                Content="⏹  Cancel" Classes="DangerBtn"
                                IsEnabled="False" Click="OnCancelClick"
                                ToolTip.Tip="Cancel the burn operation"/>
                    </Grid>

                    <ProgressBar x:Name="BurnProgressBar" Classes="BurnProgress" Value="0"/>

                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <TextBlock x:Name="TxtBurnStatus" Text="Ready."
                                   Foreground="#5A7A9A" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtCurrentSpeed" Grid.Column="1"
                                   Text="" Foreground="#1E90FF" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock x:Name="TxtETA" Grid.Column="2"
                                   Text="" Foreground="#5A7A9A" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock x:Name="TxtBurnPct" Grid.Column="3"
                                   Text="0%" Foreground="#E8F0FE" FontSize="11"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Disc Visualization -->
                    <Border x:Name="DiscVizBorder" Background="#0A1520" CornerRadius="8"
                            Padding="8" IsVisible="False"
                            ToolTip.Tip="Real-time disc burning visualization — shows LBA position on the physical disc spiral">
                        <views:DiscVisualizationControl x:Name="DiscViz" Height="200"/>
                    </Border>

                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Text="Log" Classes="SectionHeader" VerticalAlignment="Center"/>
                        <Button x:Name="BtnClearLog" Grid.Column="1"
                                Content="🧹 Clear" Classes="ActionBtn"
                                HorizontalAlignment="Right" Click="OnClearLogClick"
                                ToolTip.Tip="Clear the log output"/>
                    </Grid>

                    <TextBox x:Name="TxtLog" Classes="LogBox" Height="180"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
