<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenBurningSuite.Views.SplashWindow"
        Title="Open Burning Suite"
        Width="420" Height="300"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        CanResize="False"
        Background="#060D18"
        SystemDecorations="None">

    <Border BorderBrush="#1E3450" BorderThickness="1">
        <Grid>
            <Border>
                <Border.Background>
                    <ImageBrush Stretch="Fill"
                                Source="avares://OpenBurningSuite/Assets/splash-bg.png"/>
                </Border.Background>
            </Border>

            <!-- Close button (About mode) -->
            <Button x:Name="CloseButton" IsVisible="False"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,8,8,0" Width="28" Height="28"
                    Background="#1A2A3A" BorderThickness="1"
                    BorderBrush="#1E3450" CornerRadius="4"
                    Cursor="Hand" Click="OnCloseClick">
                <TextBlock Text="✕" FontSize="14" Foreground="#5A7A9A"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>

            <!-- Content -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                <StackPanel HorizontalAlignment="Center" Spacing="6">
                    <Image Width="64" Height="64"
                           Source="avares://OpenBurningSuite/icon.png"
                           HorizontalAlignment="Center"/>

                    <TextBlock Text="Open Burning Suite"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#E8F0FE"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="VersionText"
                               FontSize="12"
                               Foreground="#7AA0C0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,10,0,0">
                    <TextBlock Text="Created by SvenGDK &amp; marcelofrau"
                               FontSize="11" Foreground="#3A5A6A"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="LinkText"
                               FontSize="11"
                               Foreground="#5BC0FF"
                               HorizontalAlignment="Center"
                               Cursor="Hand"
                               PointerPressed="OnLinkClick"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
