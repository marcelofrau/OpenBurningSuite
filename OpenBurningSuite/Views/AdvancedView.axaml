<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OpenBurningSuite.Views.AdvancedView"
             Background="#0C1622">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="16">

            <!-- Header -->
            <TextBlock Text="Advanced Utilities" Classes="PageTitle"/>
            <TextBlock Text="Erase rewritable discs, format media, eject/load tray, and other advanced disc operations."
                       Classes="PageSubtitle"/>

            <!-- Drive selection (shared) -->
            <Border Classes="Card">
                <StackPanel Spacing="8">
                    <TextBlock Text="Drive" Classes="SectionHeader"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <ComboBox x:Name="CmbDrive"
                                  PlaceholderText="Select optical drive..."
                                  HorizontalAlignment="Stretch"
                                  ToolTip.Tip="Select the drive to operate on"/>
                        <Button x:Name="BtnRefreshDrives" Grid.Column="1"
                                Classes="ActionBtn"
                                Margin="6,0,0,0" Click="OnRefreshDrivesClick"
                                ToolTip.Tip="Refresh the list of available drives" MinWidth="32" MinHeight="32">
                            <Image Width="16" Height="16"
                                   Source="avares://OpenBurningSuite/Assets/Icons/16/icons8-refresh-16.png"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Eject / Load Tray -->
            <Border Classes="Card">
                <StackPanel Spacing="8">
                    <TextBlock Text="Eject / Load Tray" Classes="SectionHeader"/>
                    <TextBlock Text="Open or close the disc tray on the selected drive."
                               Foreground="#5A7A9A" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="BtnEject" Classes="ActionBtn"
                                Click="OnEjectClick"
                                ToolTip.Tip="Open the disc tray">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Width="16" Height="16"
                                       Source="avares://OpenBurningSuite/Assets/Icons/16/icons8-eject-2d-16.png"/>
                                <TextBlock Text="Eject Tray" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnLoadTray" Classes="ActionBtn"
                                Click="OnLoadTrayClick"
                                ToolTip.Tip="Close the disc tray">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Width="16" Height="16"
                                       Source="avares://OpenBurningSuite/Assets/Icons/16/fluentui-open-file-folder-16.png"/>
                                <TextBlock Text="Load Tray" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Blank / Erase -->
            <Border Classes="Card">
                <StackPanel Spacing="8">
                    <TextBlock Text="Blank / Erase Rewritable Disc" Classes="SectionHeader"/>
                    <TextBlock Text="Erase CD-RW, DVD±RW, or BD-RE media before writing."
                               Foreground="#5A7A9A" FontSize="11"/>

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="BtnBlankQuick" Classes="ActionBtn"
                                Click="OnBlankQuickClick"
                                ToolTip.Tip="Quick blank only clears TOC — fast but data may be recoverable">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Width="16" Height="16"
                                       Source="avares://OpenBurningSuite/Assets/Icons/16/icons8-lightning-bolt-3d-16.png"/>
                                <TextBlock Text="Quick Blank" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnBlankFull" Classes="ActionBtn"
                                Click="OnBlankFullClick"
                                ToolTip.Tip="Full blank overwrites entire disc — slower but more thorough">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Width="16" Height="16"
                                       Source="avares://OpenBurningSuite/Assets/Icons/16/icons8-erase-16.png"/>
                                <TextBlock Text="Full Blank" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Format Disc -->
            <Border Classes="Card">
                <StackPanel Spacing="8">
                    <TextBlock Text="Format Disc" Classes="SectionHeader"/>
                    <TextBlock Text="Format DVD+RW, DVD-RAM, BD-R, BD-RE, or HD DVD-RW media. Required before first use on some media types."
                               Foreground="#5A7A9A" FontSize="11"/>

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="BtnFormatQuick" Classes="ActionBtn"
                                Click="OnFormatQuickClick"
                                ToolTip.Tip="Quick format — prepares disc for use without full surface certification">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Width="16" Height="16"
                                       Source="avares://OpenBurningSuite/Assets/Icons/16/icons8-lightning-bolt-3d-16.png"/>
                                <TextBlock Text="Quick Format" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnFormatFull" Classes="ActionBtn"
                                Click="OnFormatFullClick"
                                ToolTip.Tip="Full format with certification — slower but ensures disc integrity">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Width="16" Height="16"
                                       Source="avares://OpenBurningSuite/Assets/Icons/16/icons8-cd-3d-16.png"/>
                                <TextBlock Text="Full Format" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Progress & Log -->
            <Border Classes="Card">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Progress" Classes="SectionHeader"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnCancelOp" Grid.Column="1"
                                Classes="DangerBtn"
                                IsEnabled="False" Click="OnCancelOpClick"
                                ToolTip.Tip="Cancel the current operation">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Width="16" Height="16"
                                       Source="avares://OpenBurningSuite/Assets/Icons/16/icons8-stop-2d-16.png"/>
                                <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ProgressBar x:Name="OperationProgressBar" Classes="BurnProgress" Value="0"/>

                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock x:Name="TxtOperationStatus" Text="Ready."
                                   Foreground="#5A7A9A" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtOperationETA" Grid.Column="1"
                                   Text="" Foreground="#5A7A9A" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock x:Name="TxtOperationPct" Grid.Column="2"
                                   Text="0%" Foreground="#E8F0FE" FontSize="11"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Text="Log" Classes="SectionHeader" VerticalAlignment="Center"/>
                        <Button x:Name="BtnClearLog" Grid.Column="1"
                                Classes="ActionBtn"
                                HorizontalAlignment="Right" Click="OnClearLogClick"
                                ToolTip.Tip="Clear the log output">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Width="16" Height="16"
                                       Source="avares://OpenBurningSuite/Assets/Icons/16/icons8-erase-16.png"/>
                                <TextBlock Text="Clear" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBox x:Name="TxtLog" Classes="LogBox" Height="180"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
